NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ADMIN_EMAILS=admin@example.com
AUTH_SESSION_SECRET=replace-with-long-random-string
NEXT_PUBLIC_OAUTH_PROVIDERS=google,github
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAIL_FROM_EMAIL=notifications@fabriclab.dev
MAIL_FROM_NAME=FabricLab
MAILGUN_API_BASE_URL=https://api.mailgun.net/v3

# Optional community / support links for the public site
NEXT_PUBLIC_COMMUNITY_REPO_URL=
NEXT_PUBLIC_COMMUNITY_ISSUES_URL=
NEXT_PUBLIC_COMMUNITY_DISCUSSIONS_URL=
NEXT_PUBLIC_SUPPORT_URL=

# Optional server-side GitHub issue mirroring for community threads
# Use a token that can create issues in g-arjuna/fabriclab.
# Fine-grained PAT: grant repository access and enable "Issues: Read and write".
GITHUB_COMMUNITY_ISSUES_TOKEN=
GITHUB_COMMUNITY_ISSUE_LABELS=community,feedback
